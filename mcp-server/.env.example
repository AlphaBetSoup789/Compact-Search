# Compact MCP server — copy to .env if you load env from a file (optional)

# API key (required — get one at usecompact.dev)
ORACLE_API_KEY=your-beta-key-here

# Search and log URLs — defaults are the gate (do not change unless instructed)
ORACLE_SEARCH_API_URL=https://gate.usecompact.dev/search
ORACLE_LOG_API_URL=https://gate.usecompact.dev/log
